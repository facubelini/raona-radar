# Copiá este archivo a `.env` para correr la pipeline en local.
# En GitHub Actions, agregalas como Repository Secrets (Settings → Secrets and variables → Actions).

# --- BÚSQUEDA / DESCUBRIMIENTO ---
# Serper.dev: 2.500 búsquedas Google gratis al registrarse
# https://serper.dev/
SERPER_API_KEY=

# --- PERFORMANCE TÉCNICA ---
# Google PageSpeed Insights: sin key funciona con rate limit bajo, con key gratis es generoso
# https://console.cloud.google.com/apis/credentials (activá "PageSpeed Insights API")
PAGESPEED_API_KEY=

# --- AUTORIDAD DE DOMINIO ---
# OpenPageRank: registro instantáneo, 1.000 dominios por request
# https://www.domcop.com/openpagerank/auth/signup
OPENPAGERANK_API_KEY=

# --- GITHUB (para info de competidores que tienen orgs en GH) ---
# Personal Access Token con scope public_repo (read-only) basta
# https://github.com/settings/tokens
GITHUB_TOKEN=

# --- META AD LIBRARY (opcional) ---
# Sin token: los deep-links siguen funcionando, podés abrir la Ad Library en el browser
# Con token: conteo automático de anuncios activos
# Para anuncios comerciales: pedí acceso al programa de investigación
# https://www.facebook.com/ads/library/api/
META_ACCESS_TOKEN=
